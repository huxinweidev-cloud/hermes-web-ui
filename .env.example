# Hermes Web UI production deployment example.
# Copy to .env and fill secrets locally. Do not commit .env.

WEBUI_IMAGE=hermes-web-ui:build-deploy
WEBUI_CONTAINER_NAME=hermes-webui
PORT=6060
XAI_OAUTH_PORT=56121
HERMES_DATA_DIR=/home/ubuntu/hermes-web-ui/hermes_data
AUTH_DISABLED=false
# Generate with: openssl rand -hex 32
AUTH_TOKEN=
